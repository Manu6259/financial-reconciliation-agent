# Copy to .env and fill in. The project runs with a deterministic mock model if no key is set.
OPENAI_API_KEY=

# Optional overrides
APP_LLM_MODEL=gpt-4o-mini
APP_EMBED_MODEL=text-embedding-3-small

# Set to 1 to force the offline mock model even if a key is present (useful for fast, free, reproducible runs)
APP_USE_MOCK=0
